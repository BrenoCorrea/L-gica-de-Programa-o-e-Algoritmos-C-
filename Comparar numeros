using System;
					
public class Program
{
	public static void Main()
	{
		int x,y,z;
		String [] vet = Console.ReadLine().Split(' ');
	x = int.Parse(vet[0]);
	y = int.Parse(vet[1]);
	z = int.Parse(vet[2]);
		
	
	int menor = Math.Min(x, Math.Min(y,z));
	
		Console.WriteLine("Menor = " + menor);
	
	}
	
}
